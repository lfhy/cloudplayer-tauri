{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CloudPlayer",
  "version": "2.0.1",
  "identifier": "com.cloudplayer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CloudPlayer",
        "width": 1100,
        "height": 700,
        "resizable": true,
        "decorations": false,
        "shadow": true,
        "dataDirectory": "webview"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$TEMP/**", "$HOME/**", "**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "installerHooks": "nsis/hooks.nsh"
      }
    }
  }
}
